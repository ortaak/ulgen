# Database
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ulgen_trello?schema=public"

# NextAuth Configuration
# NEXTAUTH_URL should be your app's URL (http://localhost:3000 for development)
NEXTAUTH_URL="http://localhost:3000"

# NEXTAUTH_SECRET is used to encrypt JWT tokens
# Generate with: openssl rand -base64 32
# IMPORTANT: Change this in production!
NEXTAUTH_SECRET="your-super-secret-key-change-in-production-minimum-32-characters-long"

# Google OAuth (Optional)
# Get these from: https://console.cloud.google.com/
# Leave empty if you don't want to use Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Node Environment
NODE_ENV="development"

# UploadThing (File Storage) — v7
# Dashboard: https://uploadthing.com/dashboard → App → API Keys → Token
# Tek değişken yeterli (v7'de SECRET + APP_ID yerine TOKEN kullanılıyor)
UPLOADTHING_TOKEN="eyJhcGlLZXki..."